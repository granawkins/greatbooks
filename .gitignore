# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# backups
greatbooks.db.backup

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# database
greatbooks.db
greatbooks.db-shm
greatbooks.db-wal

# corpus data (audio, raw HTML, commentary)
/data/*/raw/
/data/*/audio/
/data/*/commentary/

# generated cover art
/public/covers/

# api cost logs (keep cost_log.py, ignore the actual log data)
/logs/api_costs.jsonl

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
__pycache__
.venv/

# google cloud credentials
google-credentials.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# audit reports
AUDIT_*
.next.backup/
/public/covers/
